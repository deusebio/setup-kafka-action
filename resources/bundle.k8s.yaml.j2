applications:
  kafka:
    channel: 3/stable
    charm: kafka-k8s
    scale: {{ num_brokers }}
    revision: 56
    constraints: arch=amd64
  zookeeper:
    channel: 3/stable
    charm: zookeeper-k8s
    scale: {{ num_zk_servers }}
    revision: 51
    constraints: arch=amd64
  user:
    channel: latest/stable
    charm: data-integrator
    scale: 1
    revision: 41
    options:
      consumer-group-prefix: cg
      extra-user-roles: {{ user_roles }}
      topic-name: {{ topic_name }}
    constraints: arch=amd64

bundle: kubernetes
description: A fast, secure and fault-tolerant Apache Kafka, supported by Apache ZooKeeper
issues: https://github.com/canonical/kafka-k8s-bundle/issues/new
name: kafka-k8s-bundle
relations:
- - kafka:zookeeper
  - zookeeper:zookeeper
- - user:kafka
  - kafka:kafka-client
source: https://github.com/canonical/kafka-k8s-bundle